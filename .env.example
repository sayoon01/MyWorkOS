# Ollama (로컬 LLM)
OLLAMA_API_BASE=http://localhost:11434

# Google AI / Vertex
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Redis
REDIS_URL=redis://localhost:6379/0

# Gateway — Telegram (Phase 1)
TELEGRAM_BOT_TOKEN=
AGENT_DEBUG=1

# Gateway — Slack/Teams (Phase 2, 보류)
WEBHOOK_PORT=8080

# Heartbeat (Phase 2)
HEARTBEAT_ENABLED=1
HEARTBEAT_TARGET_USER_ID=
# 프로젝트 루트에서 실행 시 상대경로 가능. 절대경로 예:
# HEARTBEAT_UPLOAD_DIR=/home/keti_spark1/yune/keti-workOS/data/uploads
HEARTBEAT_UPLOAD_DIR=data/uploads
HEARTBEAT_CHECK_INTERVAL_SEC=10
